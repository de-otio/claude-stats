{
  "name": "@deotio/claude-stats-infra",
  "version": "0.1.0",
  "description": "AWS CDK infrastructure for claude-stats — deploy your own instance",
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "files": [
    "dist/lib/**/*.js",
    "dist/lib/**/*.d.ts",
    "dist/lib/**/*.js.map",
    "lambda/**/*",
    "graphql/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "cdk": "cdk",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@claude-stats/core": "*",
    "source-map-support": "^0.5.21"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.175.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "aws-cdk": "^2.175.0",
    "aws-cdk-lib": "^2.175.0",
    "constructs": "^10.4.2"
  }
}
